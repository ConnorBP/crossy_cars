# Roady Car local development configuration. Copy to .env and replace values.
# Never commit .env. Production Worker secrets must be set with `wrangler secret put`.

# Game client / local Worker endpoint
LEADERBOARD_API_URL=http://127.0.0.1:8787
ROADY_LEADERBOARD_CLIENT_HMAC_KEY=generate-a-random-local-client-key
# Additive v3 nuisance key embedded in the public client. Must match the
# v3.client.1 entry in LB_V3_CLIENT_HMAC_KEYS_JSON.
ROADY_V3_CLIENT_HMAC_KEY=generate-a-distinct-random-local-v3-client-key

# Cloudflare Worker secrets
LB_SESSION_HMAC_KEY=generate-at-least-32-random-bytes
LB_CLIENT_HMAC_KEY=must-match-the-client-HMAC-key-for-the-target-build
LB_IP_HASH_PEPPER=generate-at-least-32-random-bytes
LB_ADMIN_TOKEN=generate-at-least-32-random-bytes

# Additive v3 Worker configuration. Keep the production gate false until all
# protocol parity/deployment checks pass; the checked-in Worker also retains
# its independent fail-closed parity latch.
ROADY_V3_RANKED_ENABLED=false
LB_V3_PROOF_HMAC_KEY=generate-at-least-32-random-bytes
LB_V3_SEED_ENCRYPTION_KEY=base64url-encoded-exactly-32-random-bytes
LB_V3_SEED_KEY_ID=v3.seed.1
LB_V3_EVIDENCE_CAPABILITY_KEY=generate-at-least-32-random-bytes
LB_V3_CLIENT_HMAC_KEYS_JSON={"v3.client.1":"must-match-ROADY_V3_CLIENT_HMAC_KEY"}

# Cloudflare Turnstile documented test keys for local development only.
# Use real widget/secret values in production.
LB_TURNSTILE_SITE_KEY=1x00000000000000000000AA
LB_TURNSTILE_SECRET=1x0000000000000000000000000000000AA
