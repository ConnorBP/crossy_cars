{
  "name": "roady-leaderboard",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker backend for the Roady Car leaderboard (D1 + Turnstile + HMAC score submission).",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:d1-restoration": "node scripts/test-d1-restoration.mjs",
    "test:d1-v3": "node scripts/test-d1-v3.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create roady_leaderboard",
    "db:migrate:local": "wrangler d1 migrations apply roady_leaderboard --local",
    "db:migrate:remote": "wrangler d1 migrations apply roady_leaderboard --remote",
    "db:query:local": "wrangler d1 execute roady_leaderboard --local",
    "db:query:remote": "wrangler d1 execute roady_leaderboard --remote",
    "secret:put": "wrangler secret put",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20250708.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
